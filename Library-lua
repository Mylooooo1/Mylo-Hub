task.spawn(function()
    game:GetService("RunService").RenderStepped:Connect(function()
        if magnetToPlayerEnabled and selectedMagnetTarget ~= "" then
            local targetPlayer = game.Players:FindFirstChild(selectedMagnetTarget)
            
            if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local targetRP = targetPlayer.Character.HumanoidRootPart
                local myRP = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                
                if myRP then
                    -- On calcule la position cible : Derrière lui + l'offset de hauteur
                    local goalCFrame = targetRP.CFrame * CFrame.new(0, magnetHeightOffset, magnetFollowDistance)
                    local dist = (myRP.Position - goalCFrame.Position).Magnitude
                    
                    if dist > 0.5 then -- Petite zone morte pour éviter les tremblements
                        -- Téléportation fluide vers la position calculée
                        myRP.CFrame = myRP.CFrame:Lerp(goalCFrame, 0.15)
                        
                        -- Annule la vélocité pour un mouvement propre
                        myRP.Velocity = Vector3.new(0, 0, 0)
                    end
                end
            end
        end
    end)
end)


