local ChatTab = Window:CreateTab("Chat Logger", 4483362458)
local TextChatService = game:GetService("TextChatService")
local playerColors = {}
local lastMessages = {} -- Pour filtrer les doublons

-- Fonction pour obtenir une couleur vive
local function getPlayerColor(playerName)
    if not playerColors[playerName] then
        local r = math.random(100, 255)
        local g = math.random(100, 255)
        local b = math.random(100, 255)
        playerColors[playerName] = string.format("rgb(%d,%d,%d)", r, g, b)
    end
    return playerColors[playerName]
end

ChatTab:CreateSection("Historique (Scroll vers le bas)")

-- Fonction pour ajouter un message proprement
local function addMessage(senderName, msg)
    local time = os.date("%H:%M")
    
    -- Anti-doublon : On ignore si c'est exactement le même message envoyé au même moment
    local msgKey = senderName .. msg
    if lastMessages[msgKey] and tick() - lastMessages[msgKey] < 0.2 then return end
    lastMessages[msgKey] = tick()

    local color = getPlayerColor(senderName)
    local formattedText = string.format("[%s] <font color='%s'><b>%s</b></font>: %s", time, color, senderName, msg)
    
    -- Création d'un Label par message (permet de remonter/descendre le chat)
    ChatTab:CreateLabel(formattedText)
end

-- 1. ÉCOUTEUR TEXTCHATSERVICE (Nouveau Chat)
if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    TextChatService.OnIncomingMessage = function(message)
        if message.TextSource then
            addMessage(message.TextSource.Name, message.Text)
        end
    end
end

-- 2. ÉCOUTEUR LEGACY (Ancien Chat)
local function hookPlayer(player)
    player.Chatted:Connect(function(msg)
        -- On n'ajoute que si le nouveau service n'est pas actif pour éviter les doublons
        if TextChatService.ChatVersion ~= Enum.ChatVersion.TextChatService then
            addMessage(player.Name, msg)
        end
    end)
end

for _, player in pairs(game.Players:GetPlayers()) do hookPlayer(player) end
game.Players.PlayerAdded:Connect(hookPlayer)

