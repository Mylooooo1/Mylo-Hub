local RunService = game:GetService("RunService")
local StatsService = game:GetService("Stats")
local CoreGui = game:GetService("CoreGui")

-- Création de l'interface visuelle
local OverlayGui = Instance.new("ScreenGui")
local StatLabel = Instance.new("TextLabel")

-- Sécurité pour éviter que le GUI ne soit supprimé par le jeu
OverlayGui.Name = "PerfOverlay_" .. math.random(100, 999)
OverlayGui.Parent = CoreGui -- Utilise CoreGui pour passer au-dessus de tout
OverlayGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

StatLabel.Parent = OverlayGui
StatLabel.BackgroundTransparency = 1 -- Transparent
StatLabel.Position = UDim2.new(1, -10, 0, 10) -- En haut à droite (avec 10px de marge)
StatLabel.AnchorPoint = Vector2.new(1, 0) -- Ancre à droite
StatLabel.Size = UDim2.new(0, 200, 0, 50)
StatLabel.Font = Enum.Font.Code -- Style "Hacker/Console"
StatLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
StatLabel.TextSize = 16
StatLabel.TextXAlignment = Enum.TextXAlignment.Right
StatLabel.RichText = true -- Pour gérer les couleurs par mot
StatLabel.TextStrokeTransparency = 0.5 -- Petit contour noir pour lire partout

-- Variables de calcul
local fpsCount = 0
local lastUpdate = tick()

-- Mise à jour en temps réel
RunService.RenderStepped:Connect(function()
    fpsCount = fpsCount + 1
    local now = tick()
    
    if now - lastUpdate >= 1 then
        local fps = math.floor(fpsCount / (now - lastUpdate))
        local ping = math.floor(StatsService.Network.ServerStatsItem["Data Ping"]:GetValue())
        
        -- Choix des couleurs
        local fColor = fps > 50 and "#00FF00" or (fps > 30 and "#FFA500" or "#FF0000")
        local pColor = ping < 100 and "#00FF00" or (ping < 200 and "#FFA500" or "#FF0000")

        StatLabel.Text = string.format(
            "FPS: <font color='%s'>%d</font>\nPING: <font color='%s'>%d ms</font>",
            fColor, fps, pColor, ping
        )
        
        fpsCount = 0
        lastUpdate = now
    end
end)

