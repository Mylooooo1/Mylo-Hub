local RunService = game:GetService("RunService")
local lp = game:GetService("Players").LocalPlayer

_G.airWalkEnabled = false 
local airPart = nil
local lastY = 0

-- 2. NETTOYAGE
local function cleanup()
    _G.airWalkEnabled = false
    if airPart then 
        airPart:Destroy() 
        airPart = nil 
    end
end

-- 3. CRÉATION DU TOGGLE
local MovementTab = Window:CreateTab("Fun", 4483362458)

_G.StabilizerToggle = MovementTab:CreateToggle({
   Name = "⚖️ Stabilisateur d'Air",
   CurrentValue = false,
   Flag = "SteadyAirWalk",
   Callback = function(Value)
       if Value then
           cleanup()
           _G.airWalkEnabled = true
           
           local char = lp.Character
           local hrp = char and char:FindFirstChild("HumanoidRootPart")
           if hrp then lastY = hrp.Position.Y - 3.22 end

           airPart = Instance.new("Part")
           airPart.Name = "AirStab_Final"
           airPart.Size = Vector3.new(6, 0.5, 6) -- Taille compacte
           airPart.Transparency = 0.8
           airPart.Anchored = true
           airPart.CanCollide = true
           airPart.Color = Color3.fromRGB(255, 255, 255)
           airPart.Parent = workspace
           
           task.spawn(function()
               while _G.airWalkEnabled and airPart do
                   local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                   
                   if root then
                       -- CALCUL DE LA DISTANCE :
                       -- Si l'écart entre tes pieds et la plaque est grand, ça veut dire que tu Fly.
                       local targetY = root.Position.Y - 3.22
                       local diffY = math.abs(targetY - lastY)

                       if diffY > 0.5 then
                           -- Tu es en Fly : la plaque se téléporte sous toi
                           lastY = targetY
                       end

                       -- Dans tous les cas, elle te suit en X et Z
                       airPart.CFrame = CFrame.new(root.Position.X, lastY, root.Position.Z)
                   end
                   RunService.Stepped:Wait()
               end
               cleanup()
           end)
       else
           cleanup()
       end
   end,
})


